{
  "name": "finance_reconciliation_daily",
  "tags": {
    "project": "finance-reconciliation-engine",
    "environment": "prod",
    "managed_by": "terraform+adf"
  },
  "job_clusters": [
    {
      "job_cluster_key": "recon_cluster",
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "autoscale": {
          "min_workers": 2,
          "max_workers": 6
        },
        "azure_attributes": {
          "availability": "SPOT_WITH_FALLBACK_AZURE",
          "spot_bid_max_price": -1
        },
        "spark_conf": {
          "spark.sql.extensions": "io.delta.sql.DeltaSparkSessionExtension",
          "spark.sql.catalog.spark_catalog": "org.apache.spark.sql.delta.catalog.DeltaCatalog",
          "spark.databricks.delta.optimizeWrite.enabled": "true",
          "spark.databricks.delta.autoCompact.enabled": "true"
        },
        "custom_tags": {
          "project": "finance-reconciliation-engine",
          "cost_center": "finance-data-engineering"
        }
      }
    }
  ],
  "tasks": [
    {
      "task_key": "bronze_ingest",
      "notebook_task": {
        "notebook_path": "/Repos/production/finance-reconciliation-engine/databricks/notebooks/01_bronze_ingest",
        "base_parameters": {
          "catalog": "finance_recon"
        }
      },
      "job_cluster_key": "recon_cluster",
      "timeout_seconds": 1800,
      "max_retries": 2,
      "retry_on_timeout": false
    },
    {
      "task_key": "silver_standardise",
      "depends_on": [{ "task_key": "bronze_ingest" }],
      "notebook_task": {
        "notebook_path": "/Repos/production/finance-reconciliation-engine/databricks/notebooks/02_silver_standardise",
        "base_parameters": {
          "catalog": "finance_recon"
        }
      },
      "job_cluster_key": "recon_cluster",
      "timeout_seconds": 1800,
      "max_retries": 1
    },
    {
      "task_key": "reconciliation_engine",
      "depends_on": [{ "task_key": "silver_standardise" }],
      "notebook_task": {
        "notebook_path": "/Repos/production/finance-reconciliation-engine/databricks/notebooks/03_reconciliation_engine",
        "base_parameters": {
          "catalog": "finance_recon",
          "amount_tolerance": "1.00"
        }
      },
      "job_cluster_key": "recon_cluster",
      "timeout_seconds": 2400,
      "max_retries": 1
    },
    {
      "task_key": "gold_kpis",
      "depends_on": [{ "task_key": "reconciliation_engine" }],
      "notebook_task": {
        "notebook_path": "/Repos/production/finance-reconciliation-engine/databricks/notebooks/04_gold_kpis",
        "base_parameters": {
          "catalog": "finance_recon"
        }
      },
      "job_cluster_key": "recon_cluster",
      "timeout_seconds": 1200,
      "max_retries": 1
    }
  ],
  "email_notifications": {
    "on_failure": ["andiswacebekhulu1@gmail.com"],
    "on_success": []
  },
  "max_concurrent_runs": 1,
  "schedule": {
    "quartz_cron_expression": "0 0 1 * * ?",
    "timezone_id": "Africa/Johannesburg"
  }
}
